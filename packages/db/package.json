{
  "name": "@testworx/db",
  "private": true,
  "version": "0.1.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "echo db package build complete",
    "lint": "echo db package lint complete",
    "test": "echo db package tests are covered in @testworx/lib",
    "prisma:generate": "node ./scripts/run-prisma.cjs generate --schema ./prisma/schema.prisma",
    "prisma:status": "node ./scripts/run-prisma.cjs migrate status --schema ./prisma/schema.prisma",
    "prisma:migrate": "node ./scripts/run-prisma.cjs migrate deploy --schema ./prisma/schema.prisma",
    "prisma:seed": "node ./scripts/run-seed.cjs",
    "verify": "node ./scripts/verify.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@testworx/types": "*",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "tsx": "^4.19.3"
  },
  "prisma": {
    "seed": "node ./scripts/run-seed.cjs"
  }
}

