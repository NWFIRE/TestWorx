generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  platform_admin
  tenant_admin
  office_admin
  technician
  customer_user
}

enum TenantStatus {
  active
  trialing
  suspended
}

enum InspectionType {
  fire_extinguisher
  fire_alarm
  wet_fire_sprinkler
  joint_commission_fire_sprinkler
  backflow
  fire_pump
  dry_fire_sprinkler
  kitchen_suppression
  industrial_suppression
  emergency_exit_lighting
}

enum InspectionStatus {
  to_be_completed
  scheduled
  in_progress
  completed
  invoiced
  cancelled
  follow_up_required
}

enum InspectionClassification {
  standard
  call_in
  follow_up
  emergency
}

enum ReportStatus {
  draft
  submitted
  finalized
}

enum ReportCorrectionState {
  none
  admin_edit_in_progress
  reissued_to_technician
}

enum RecurrenceFrequency {
  ONCE
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum AttachmentKind {
  photo
  pdf
  file
}

enum AttachmentSource {
  uploaded
  generated
}

enum SignatureKind {
  technician
  customer
}

enum InspectionDocumentType {
  EXTERNAL_CUSTOMER_FORM
}

enum InspectionDocumentStatus {
  UPLOADED
  ANNOTATED
  READY_FOR_SIGNATURE
  SIGNED
  EXPORTED
}

enum InspectionAmendmentType {
  reschedule
  reassignment
  scope_change
}

enum StripeWebhookEventStatus {
  received
  processing
  processed
  failed
}

enum QuickBooksConnectionMode {
  sandbox
  live
}

enum QuoteStatus {
  draft
  ready_to_send
  sent
  viewed
  approved
  declined
  expired
  converted
  cancelled
}

enum QuoteSyncStatus {
  not_synced
  sync_pending
  synced
  sync_error
}

enum QuoteDeliveryStatus {
  not_sent
  pending
  sent
  error
}

enum QuoteReminderType {
  sent_not_viewed_first
  sent_not_viewed_second
  viewed_pending_first
  viewed_pending_second
  expiring_soon
  expired_follow_up
  manual_follow_up
}

enum QuoteReminderDispatchStatus {
  pending
  sent
  skipped
  failed
}

model SubscriptionPlan {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  monthlyPriceCents Int
  maxTenants        Int?
  maxUsers          Int?
  featureFlags      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenants           Tenant[]
}

model Tenant {
  id                        String                 @id @default(cuid())
  slug                      String                 @unique
  name                      String
  status                    TenantStatus           @default(active)
  timezone                  String                 @default("America/Chicago")
  branding                  Json?
  subscriptionPlanId        String?
  billingEmail              String?
  stripeCustomerId          String?                @unique
  stripeSubscriptionId      String?                @unique
  stripeSubscriptionStatus  String?
  stripePriceId             String?
  defaultServiceFeeCode     String?                @default("SERVICE_FEE")
  defaultServiceFeeUnitPrice Float?
  stripeCurrentPeriodEndsAt DateTime?
  stripeCancelAtPeriodEnd   Boolean                @default(false)
  stripeSubscriptionSyncedAt DateTime?
  stripeSubscriptionEventCreatedAt DateTime?
  stripeSubscriptionEventId String?
  quickbooksRealmId          String?                @unique
  quickbooksCompanyName      String?
  quickbooksConnectionMode   QuickBooksConnectionMode?
  quickbooksAccessToken      String?
  quickbooksRefreshToken     String?
  quickbooksTokenExpiresAt   DateTime?
  quickbooksConnectedAt      DateTime?
  quoteReminderSettings      Json?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  subscriptionPlan          SubscriptionPlan?      @relation(fields: [subscriptionPlanId], references: [id])
  users                     User[]
  customerCompanies         CustomerCompany[]
  sites                     Site[]
  assets                    Asset[]
  inspections               Inspection[]
  inspectionTasks           InspectionTask[]
  inspectionReports         InspectionReport[]
  recurrences               InspectionRecurrence[]
  attachments               Attachment[]
  signatures                Signature[]
  deficiencies              Deficiency[]
  billingSummaries          InspectionBillingSummary[]
  inspectionDocuments       InspectionDocument[]
  auditLogs                 AuditLog[]
  reportCorrectionEvents    ReportCorrectionEvent[]
  inspectionAmendments      InspectionAmendment[]
  inspectionTechnicianAssignments InspectionTechnicianAssignment[]
  stripeWebhookEvents       StripeWebhookEvent[]
  serviceFeeRules           ServiceFeeRule[]
  quickbooksCatalogItems    QuickBooksCatalogItem[]
  quickBooksItemMaps        QuickBooksItemMap[]
  quickBooksItemCache       QuickBooksItemCache[]
  quickbooksCatalogItemAliases QuickBooksCatalogItemAlias[]
  billingItemCatalogMatches BillingItemCatalogMatch[]
  accountInvitations        AccountInvitation[]
  passwordResetTokens       PasswordResetToken[]
  quotes                    Quote[]
  quoteLineItems            QuoteLineItem[]
  quoteReminderDispatches   QuoteReminderDispatch[]
}

model User {
  id                  String                  @id @default(cuid())
  tenantId            String?
  customerCompanyId   String?
  email               String                  @unique
  name                String
  passwordHash        String
  role                UserRole
  isActive            Boolean                 @default(true)
  allowances          Json?
  lastLoginAt         DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  tenant              Tenant?                 @relation(fields: [tenantId], references: [id])
  customerCompany     CustomerCompany?        @relation(fields: [customerCompanyId], references: [id])
  assignedInspections Inspection[]            @relation("InspectionAssignedTechnician")
  assignedInspectionTasks InspectionTask[]    @relation("InspectionTaskAssignedTechnician")
  createdInspections  Inspection[]            @relation("InspectionCreatedBy")
  inspectionReports   InspectionReport[]      @relation("InspectionReportTechnician")
  requestedReportCorrections InspectionReport[] @relation("ReportCorrectionRequestedBy")
  resolvedReportCorrections InspectionReport[] @relation("ReportCorrectionResolvedBy")
  auditLogs           AuditLog[]
  reportCorrectionEvents ReportCorrectionEvent[] @relation("ReportCorrectionEventActor")
  createdAmendments   InspectionAmendment[]   @relation("InspectionAmendmentCreatedBy")
  inspectionAssignments InspectionTechnicianAssignment[]
  sentAccountInvitations AccountInvitation[]  @relation("AccountInvitationInvitedBy")
  acceptedAccountInvitations AccountInvitation[] @relation("AccountInvitationAcceptedBy")
  requestedPasswordResets PasswordResetToken[] @relation("PasswordResetRequestedBy")
  passwordResetTokens PasswordResetToken[]     @relation("PasswordResetUser")
  addedInspectionTasks InspectionTask[]        @relation("InspectionTaskAddedBy")
  createdQuotes       Quote[]                  @relation("QuoteCreatedBy")
  updatedQuotes       Quote[]                  @relation("QuoteUpdatedBy")
  pausedQuoteReminders Quote[]                @relation("QuoteRemindersPausedBy")
}

model CustomerCompany {
  id                        String   @id @default(cuid())
  tenantId                  String
  name                      String
  contactName               String?
  billingEmail              String?
  phone                     String?
  isTaxExempt               Boolean  @default(false)
  serviceAddressLine1       String?
  serviceAddressLine2       String?
  serviceCity               String?
  serviceState              String?
  servicePostalCode         String?
  serviceCountry            String?
  billingAddressSameAsService Boolean @default(true)
  billingAddressLine1       String?
  billingAddressLine2       String?
  billingCity               String?
  billingState              String?
  billingPostalCode         String?
  billingCountry            String?
  notes                     String?
  isActive                  Boolean  @default(true)
  paymentTermsCode          String   @default("due_on_receipt")
  customPaymentTermsLabel   String?
  customPaymentTermsDays    Int?
  quickbooksCustomerId      String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  tenant                    Tenant   @relation(fields: [tenantId], references: [id])
  users                     User[]
  sites                     Site[]
  inspections               Inspection[]
  billingSummaries          InspectionBillingSummary[]
  serviceFeeRules           ServiceFeeRule[]
  accountInvitations        AccountInvitation[]
  quotes                    Quote[]
}

model Site {
  id                String          @id @default(cuid())
  tenantId          String
  customerCompanyId String
  name              String
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  postalCode        String
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  customerCompany   CustomerCompany @relation(fields: [customerCompanyId], references: [id])
  assets            Asset[]
  inspections       Inspection[]
  deficiencies      Deficiency[]
  billingSummaries  InspectionBillingSummary[]
  serviceFeeRules   ServiceFeeRule[]
  quotes            Quote[]
}

model Asset {
  id              String           @id @default(cuid())
  tenantId        String
  siteId          String
  name            String
  assetTag        String?
  inspectionTypes InspectionType[]
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  site            Site             @relation(fields: [siteId], references: [id])
  deficiencies    Deficiency[]
}

model Inspection {
    id                    String                  @id @default(cuid())
    tenantId              String
    customerCompanyId     String
    siteId                String
    assignedTechnicianId  String?
    createdByUserId       String
    inspectionClassification InspectionClassification @default(standard)
    isPriority            Boolean                 @default(false)
    priorityAssignedAt    DateTime?
    priorityClearedAt     DateTime?
    classificationUpdatedAt DateTime?
    status                InspectionStatus        @default(to_be_completed)
    scheduledStart        DateTime
    scheduledEnd          DateTime?
    notes                 String?
    claimable             Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  customerCompany       CustomerCompany         @relation(fields: [customerCompanyId], references: [id])
  site                  Site                    @relation(fields: [siteId], references: [id])
  assignedTechnician    User?                   @relation("InspectionAssignedTechnician", fields: [assignedTechnicianId], references: [id])
  attachments           Attachment[]
  createdBy             User                    @relation("InspectionCreatedBy", fields: [createdByUserId], references: [id])
  tasks                 InspectionTask[]
  reports               InspectionReport[]
  deficiencies          Deficiency[]
  billingSummary        InspectionBillingSummary?
  documents             InspectionDocument[]
    amendments            InspectionAmendment[]   @relation("OriginalInspectionAmendments")
    replacementAmendments InspectionAmendment[]   @relation("ReplacementInspectionAmendments")
    technicianAssignments InspectionTechnicianAssignment[]
    convertedFromQuotes   Quote[]                 @relation("QuoteConvertedInspection")

    @@index([tenantId, inspectionClassification])
    @@index([tenantId, isPriority])
  }

model Quote {
  id                      String              @id @default(cuid())
  tenantId                String
  quoteNumber             String
  customerCompanyId       String
  siteId                  String?
  contactName             String?
  recipientEmail          String?
  status                  QuoteStatus         @default(draft)
  syncStatus              QuoteSyncStatus     @default(not_synced)
  deliveryStatus          QuoteDeliveryStatus @default(not_sent)
  quickbooksEstimateId    String?
  quickbooksEstimateNumber String?
  quickbooksConnectionMode QuickBooksConnectionMode?
  quickbooksCustomerId    String?
  quickbooksSyncedAt      DateTime?
  quickbooksSyncError     String?
  issuedAt                DateTime            @default(now())
  expiresAt               DateTime?
  sentAt                  DateTime?
  lastSentAt              DateTime?
  resendCount             Int                 @default(0)
  viewedAt                DateTime?
  firstViewedAt           DateTime?
  lastViewedAt            DateTime?
  viewCount               Int                 @default(0)
  customerResponseNote    String?
  lastAccessedByEmail     String?
  quoteAccessToken        String?             @unique
  quoteAccessTokenExpiresAt DateTime?
  quoteAccessTokenRevokedAt DateTime?
  quoteAccessTokenSentToEmail String?
  remindersEnabled        Boolean             @default(true)
  remindersPausedAt       DateTime?
  remindersPausedByUserId String?
  nextReminderAt          DateTime?
  lastReminderAt          DateTime?
  reminderStage           String?
  reminderCount           Int                 @default(0)
  reminderError           String?
  approvedAt              DateTime?
  declinedAt              DateTime?
  convertedAt             DateTime?
  subtotal                Float               @default(0)
  taxAmount               Float               @default(0)
  total                   Float               @default(0)
  internalNotes           String?
  customerNotes           String?
  deliverySubject         String?
  deliveryBody            String?
  lastSentToEmail         String?
  lastDeliveryMessageId   String?
  lastDeliveryError       String?
  deliveryAttempts        Int                 @default(0)
  convertedInspectionId   String?
  createdByUserId         String
  updatedByUserId         String
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  tenant                  Tenant              @relation(fields: [tenantId], references: [id])
  customerCompany         CustomerCompany     @relation(fields: [customerCompanyId], references: [id])
  site                    Site?               @relation(fields: [siteId], references: [id])
  createdBy               User                @relation("QuoteCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy               User                @relation("QuoteUpdatedBy", fields: [updatedByUserId], references: [id])
  remindersPausedBy       User?               @relation("QuoteRemindersPausedBy", fields: [remindersPausedByUserId], references: [id])
  convertedInspection     Inspection?         @relation("QuoteConvertedInspection", fields: [convertedInspectionId], references: [id])
  lineItems               QuoteLineItem[]
  reminderDispatches      QuoteReminderDispatch[]

  @@unique([tenantId, quoteNumber])
  @@index([tenantId, status])
  @@index([tenantId, syncStatus])
  @@index([tenantId, customerCompanyId])
  @@index([tenantId, siteId])
  @@index([tenantId, issuedAt])
  @@index([tenantId, sentAt])
  @@index([tenantId, expiresAt])
  @@index([tenantId, remindersEnabled])
  @@index([tenantId, nextReminderAt])
}

model QuoteLineItem {
  id                String   @id @default(cuid())
  tenantId          String
  quoteId           String
  sortOrder         Int      @default(0)
  internalCode      String
  title             String
  description       String?
  quantity          Float    @default(1)
  unitPrice         Float    @default(0)
  discountAmount    Float    @default(0)
  taxable           Boolean  @default(false)
  total             Float    @default(0)
  qbItemId          String?
  inspectionType    InspectionType?
  category          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  quote             Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([tenantId, quoteId])
  @@index([tenantId, internalCode])
  @@index([tenantId, qbItemId])
}

model QuoteReminderDispatch {
  id            String                     @id @default(cuid())
  tenantId      String
  quoteId       String
  reminderType  QuoteReminderType
  status        QuoteReminderDispatchStatus @default(pending)
  dedupeKey     String?                    @unique
  recipientEmail String?
  scheduledFor  DateTime?
  attemptedAt   DateTime?
  sentAt        DateTime?
  messageId     String?
  error         String?
  metadata      Json?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  tenant        Tenant                     @relation(fields: [tenantId], references: [id])
  quote         Quote                      @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([tenantId, quoteId])
  @@index([tenantId, status])
  @@index([tenantId, reminderType])
}

model InspectionTechnicianAssignment {
  id           String     @id @default(cuid())
  tenantId     String
  inspectionId String
  technicianId String
  createdAt    DateTime   @default(now())
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  inspection   Inspection @relation(fields: [inspectionId], references: [id])
  technician   User       @relation(fields: [technicianId], references: [id])

  @@unique([inspectionId, technicianId])
  @@index([tenantId, inspectionId])
  @@index([tenantId, technicianId])
}

model InspectionTask {
  id             String           @id @default(cuid())
  tenantId       String
  inspectionId   String
  inspectionType InspectionType
  addedByUserId  String?
  assignedTechnicianId String?
  dueMonth       String?
  dueDate        DateTime?
  schedulingStatus String        @default("scheduled_now")
  notes          String?
  status         InspectionStatus @default(to_be_completed)
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  inspection     Inspection       @relation(fields: [inspectionId], references: [id])
  addedBy        User?            @relation("InspectionTaskAddedBy", fields: [addedByUserId], references: [id])
  assignedTechnician User?        @relation("InspectionTaskAssignedTechnician", fields: [assignedTechnicianId], references: [id])
  recurrence     InspectionRecurrence?
  report         InspectionReport?
  
  @@index([inspectionId, inspectionType])
  @@index([tenantId, assignedTechnicianId])
  @@index([tenantId, dueMonth])
  @@index([tenantId, schedulingStatus])
}

model InspectionRecurrence {
  id               String              @id @default(cuid())
  tenantId         String
  inspectionTaskId String              @unique
  frequency        RecurrenceFrequency
  intervalCount    Int                 @default(1)
  seriesId         String
  anchorScheduledStart DateTime?
  nextDueAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  inspectionTask   InspectionTask      @relation(fields: [inspectionTaskId], references: [id])

  @@index([tenantId, seriesId])
}

model InspectionReport {
  id                            String                @id @default(cuid())
  tenantId                      String
  inspectionId                  String
  inspectionTaskId              String                @unique
  technicianId                  String?
  status                        ReportStatus          @default(draft)
  correctionState               ReportCorrectionState @default(none)
  correctionReason              String?
  correctionRequestedAt         DateTime?
  correctionRequestedByUserId   String?
  correctionResolvedAt          DateTime?
  correctionResolvedByUserId    String?
  contentJson                   Json?
  autosaveVersion               Int                   @default(1)
  finalizedAt                   DateTime?
  createdAt                     DateTime              @default(now())
  updatedAt                     DateTime              @updatedAt
  tenant                        Tenant                @relation(fields: [tenantId], references: [id])
  inspection                    Inspection            @relation(fields: [inspectionId], references: [id])
  task                          InspectionTask        @relation(fields: [inspectionTaskId], references: [id])
  technician                    User?                 @relation("InspectionReportTechnician", fields: [technicianId], references: [id])
  correctionRequestedBy         User?                 @relation("ReportCorrectionRequestedBy", fields: [correctionRequestedByUserId], references: [id], onDelete: SetNull)
  correctionResolvedBy          User?                 @relation("ReportCorrectionResolvedBy", fields: [correctionResolvedByUserId], references: [id], onDelete: SetNull)
  attachments                   Attachment[]
  signatures                    Signature[]
  deficiencies                  Deficiency[]
  correctionEvents              ReportCorrectionEvent[]

  @@index([tenantId, correctionState])
}

model ReportCorrectionEvent {
  id             String   @id @default(cuid())
  tenantId       String
  reportId       String
  actionType     String
  reason         String?
  previousStatus String?
  newStatus      String?
  snapshotJson   Json?
  actedByUserId  String
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  report         InspectionReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  actedBy        User     @relation("ReportCorrectionEventActor", fields: [actedByUserId], references: [id])

  @@index([tenantId, reportId])
  @@index([tenantId, createdAt])
}

model Attachment {
  id                 String            @id @default(cuid())
  tenantId           String
  inspectionId       String?
  inspectionReportId String?
  kind               AttachmentKind
  source             AttachmentSource  @default(uploaded)
  fileName           String
  mimeType           String
  storageKey         String
  customerVisible    Boolean           @default(false)
  createdAt          DateTime          @default(now())
  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  inspection         Inspection?       @relation(fields: [inspectionId], references: [id])
  inspectionReport   InspectionReport? @relation(fields: [inspectionReportId], references: [id])
}

model Signature {
  id                 String           @id @default(cuid())
  tenantId           String
  inspectionReportId String
  signerName         String
  kind               SignatureKind
  imageDataUrl       String
  signedAt           DateTime         @default(now())
  tenant             Tenant           @relation(fields: [tenantId], references: [id])
  inspectionReport   InspectionReport @relation(fields: [inspectionReportId], references: [id])
}

model Deficiency {
  id                 String           @id @default(cuid())
  tenantId           String
  siteId             String
  inspectionId       String
  inspectionReportId String
  reportType         InspectionType
  section            String
  source             String           @default("manual")
  sourceRowKey       String
  assetId            String?
  assetTag           String?
  location           String?
  deviceType         String?
  title              String
  description        String
  severity           String
  status             String
  photoStorageKey    String?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tenant             Tenant           @relation(fields: [tenantId], references: [id])
  site               Site             @relation(fields: [siteId], references: [id])
  inspection         Inspection       @relation(fields: [inspectionId], references: [id])
  inspectionReport   InspectionReport @relation(fields: [inspectionReportId], references: [id])
  asset              Asset?           @relation(fields: [assetId], references: [id])

  @@unique([inspectionReportId, source, section, sourceRowKey])
  @@index([tenantId, status])
  @@index([tenantId, siteId])
  @@index([tenantId, inspectionId])
}

model InspectionBillingSummary {
  id                String       @id @default(cuid())
  tenantId          String
  inspectionId      String       @unique
  customerCompanyId String
  siteId            String
  status            String       @default("draft")
  quickbooksSyncStatus String?   @default("not_synced")
  quickbooksInvoiceId String?
  quickbooksInvoiceNumber String?
  quickbooksConnectionMode QuickBooksConnectionMode?
  quickbooksCustomerId String?
  quickbooksSyncedAt  DateTime?
  quickbooksSyncError String?
  items             Json
  subtotal          Float        @default(0)
  notes             String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  inspection        Inspection   @relation(fields: [inspectionId], references: [id])
  customerCompany   CustomerCompany @relation(fields: [customerCompanyId], references: [id])
  site              Site         @relation(fields: [siteId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, customerCompanyId])
  @@index([tenantId, siteId])
}

model ServiceFeeRule {
  id                String          @id @default(cuid())
  tenantId          String
  customerCompanyId String?
  siteId            String?
  city              String?
  state             String?
  zipCode           String?
  feeCode           String          @default("SERVICE_FEE")
  unitPrice         Float
  priority          Int             @default(0)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  customerCompany   CustomerCompany? @relation(fields: [customerCompanyId], references: [id])
  site              Site?           @relation(fields: [siteId], references: [id])

  @@index([tenantId, isActive, priority])
  @@index([tenantId, customerCompanyId])
  @@index([tenantId, siteId])
  @@index([tenantId, zipCode])
  @@index([tenantId, city, state])
}

model QuickBooksCatalogItem {
  id                 String   @id @default(cuid())
  tenantId           String
  quickbooksItemId   String
  name               String
  sku                String?
  itemType           String
  active             Boolean  @default(true)
  unitPrice          Float?
  incomeAccountId    String?
  incomeAccountName  String?
  rawJson            Json?
  importedAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  aliases            QuickBooksCatalogItemAlias[]
  billingItemMatches BillingItemCatalogMatch[]

  @@unique([tenantId, quickbooksItemId])
  @@index([tenantId, active, itemType])
  @@index([tenantId, name])
  @@index([tenantId, sku])
}

model QuickBooksItemMap {
  id            String   @id @default(cuid())
  tenantId      String
  integrationId String
  internalCode  String
  internalName  String
  qbItemId      String
  qbItemName    String
  qbItemType    String?
  qbSyncToken   String?
  qbActive      Boolean  @default(true)
  matchSource   String   @default("manual")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, integrationId, internalCode])
  @@index([tenantId, integrationId, qbItemId])
}

model QuickBooksItemCache {
  id             String   @id @default(cuid())
  tenantId       String
  integrationId  String
  qbItemId       String
  qbItemName     String
  normalizedName String
  qbItemType     String?
  qbActive       Boolean  @default(true)
  qbSyncToken    String?
  rawJson        Json?
  lastSyncedAt   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, integrationId, qbItemId])
  @@index([tenantId, integrationId, normalizedName])
  @@index([tenantId, integrationId, qbActive])
}

model QuickBooksCatalogItemAlias {
  id              String   @id @default(cuid())
  tenantId        String
  catalogItemId   String
  alias           String
  normalizedAlias String
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  catalogItem     QuickBooksCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([tenantId, normalizedAlias])
  @@index([tenantId, catalogItemId])
  @@index([tenantId, alias])
}

model BillingItemCatalogMatch {
  id                   String   @id @default(cuid())
  tenantId             String
  sourceKey            String
  sourceName           String
  normalizedSourceName String
  sourceCode           String?
  sourceCategory       String
  sourceReportType     String
  sourceSection        String?
  sourceField          String?
  catalogItemId        String
  confidence           Float
  matchMethod          String
  confirmedByUserId    String?
  confirmedAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
  catalogItem          QuickBooksCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sourceKey])
  @@index([tenantId, catalogItemId])
  @@index([tenantId, normalizedSourceName])
}

model InspectionDocument {
  id                     String                   @id @default(cuid())
  tenantId               String
  inspectionId           String
  fileName               String
  mimeType               String
  fileSize               Int?
  documentType           InspectionDocumentType   @default(EXTERNAL_CUSTOMER_FORM)
  label                  String?
  requiresSignature      Boolean                  @default(false)
  status                 InspectionDocumentStatus @default(UPLOADED)
  customerVisible        Boolean                  @default(false)
  originalStorageKey     String
  annotatedStorageKey    String?
  signedStorageKey       String?
  uploadedByUserId       String?
  annotatedByUserId      String?
  signedByUserId         String?
  uploadedAt             DateTime                 @default(now())
  annotatedAt            DateTime?
  signedAt               DateTime?
  exportedAt             DateTime?
  externalTransferStatus String?
  externalTransferRef    String?
  externalTransferAt     DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  tenant                 Tenant                   @relation(fields: [tenantId], references: [id])
  inspection             Inspection               @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, inspectionId])
  @@index([tenantId, status])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  actor       User?    @relation(fields: [actorUserId], references: [id])
}

model InspectionAmendment {
  id                     String                  @id @default(cuid())
  tenantId               String
  inspectionId           String
  replacementInspectionId String
  createdByUserId        String
  type                   InspectionAmendmentType @default(reschedule)
  reason                 String
  previousSnapshot       Json
  replacementSnapshot    Json
  createdAt              DateTime                @default(now())
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  inspection             Inspection              @relation("OriginalInspectionAmendments", fields: [inspectionId], references: [id])
  replacementInspection  Inspection              @relation("ReplacementInspectionAmendments", fields: [replacementInspectionId], references: [id])
  createdBy              User                    @relation("InspectionAmendmentCreatedBy", fields: [createdByUserId], references: [id])
}

model StripeWebhookEvent {
  id            String                   @id @default(cuid())
  tenantId      String?
  stripeEventId String                   @unique
  type          String
  status        StripeWebhookEventStatus @default(received)
  deliveryCount Int                      @default(1)
  stripeCreatedAt DateTime?
  stripeObjectId String?
  payload       Json
  errorMessage  String?
  processingStartedAt DateTime?
  processedAt   DateTime?
  createdAt     DateTime                 @default(now())
  tenant        Tenant?                  @relation(fields: [tenantId], references: [id])
}

model AccountInvitation {
  id                String          @id @default(cuid())
  tenantId          String
  customerCompanyId String?
  invitedByUserId   String
  acceptedByUserId  String?
  email             String
  name              String?
  role              UserRole
  allowances        Json?
  tokenHash         String          @unique
  status            String          @default("pending")
  sentAt            DateTime        @default(now())
  acceptedAt        DateTime?
  revokedAt         DateTime?
  expiresAt         DateTime
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  customerCompany   CustomerCompany? @relation(fields: [customerCompanyId], references: [id])
  invitedBy         User            @relation("AccountInvitationInvitedBy", fields: [invitedByUserId], references: [id])
  acceptedBy        User?           @relation("AccountInvitationAcceptedBy", fields: [acceptedByUserId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, email])
  @@index([tenantId, customerCompanyId])
}

model PasswordResetToken {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  requestedByUserId String
  tokenHash         String    @unique
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  user              User      @relation("PasswordResetUser", fields: [userId], references: [id])
  requestedBy       User      @relation("PasswordResetRequestedBy", fields: [requestedByUserId], references: [id])

  @@index([tenantId, userId])
  @@index([tenantId, expiresAt])
}
