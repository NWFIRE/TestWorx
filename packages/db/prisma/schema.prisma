generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  platform_admin
  tenant_admin
  office_admin
  technician
  customer_user
}

enum TenantStatus {
  active
  trialing
  suspended
}

enum InspectionType {
  fire_extinguisher
  fire_alarm
  wet_chemical_acceptance_test
  wet_fire_sprinkler
  joint_commission_fire_sprinkler
  work_order
  backflow
  fire_pump
  dry_fire_sprinkler
  kitchen_suppression
  industrial_suppression
  emergency_exit_lighting
}

enum InspectionStatus {
  to_be_completed
  scheduled
  in_progress
  completed
  invoiced
  cancelled
  follow_up_required
}

enum InspectionClassification {
  standard
  call_in
  follow_up
  emergency
}

enum ReportStatus {
  draft
  submitted
  finalized
}

enum ReportCorrectionState {
  none
  admin_edit_in_progress
  reissued_to_technician
}

enum RecurrenceFrequency {
  ONCE
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum AttachmentKind {
  photo
  pdf
  file
}

enum AttachmentSource {
  uploaded
  generated
}

enum ManualSystemCategory {
  wet_chemical
  industrial_dry_chemical
}

enum ManualDocumentType {
  installation
  inspection
  service
  owners_manual
  parts
  tech_data
  troubleshooting
  catalog
  other
}

enum ManualSearchableTextStatus {
  pending
  ready
  failed
  not_requested
}

enum SignatureKind {
  technician
  customer
}

enum InspectionDocumentType {
  EXTERNAL_CUSTOMER_FORM
}

enum InspectionDocumentStatus {
  UPLOADED
  ANNOTATED
  READY_FOR_SIGNATURE
  SIGNED
  EXPORTED
}

enum InspectionAmendmentType {
  reschedule
  reassignment
  scope_change
}

enum InspectionCloseoutRequestType {
  new_inspection
  follow_up_inspection
}

enum InspectionCloseoutRequestStatus {
  pending
  approved
  dismissed
}

enum StripeWebhookEventStatus {
  received
  processing
  processed
  failed
}

enum QuickBooksConnectionMode {
  sandbox
  live
}

enum BillingType {
  standard
  third_party
}

enum ContractProviderAccountStatus {
  active
  inactive
}

enum ProviderContractProfileStatus {
  draft
  active
  inactive
  expired
}

enum ProviderContractPricingStrategy {
  provider_rate_card
  fixed_price
  custom_rules
}

enum ProviderInvoiceGroupingMode {
  per_work_order
  per_site
  monthly_rollup
}

enum ProviderContractRatePricingMethod {
  flat_rate
  per_unit
  hourly
}

enum ServiceSiteProviderAssignmentStatus {
  active
  inactive
}

enum WorkOrderProviderSourceType {
  direct
  third_party_provider
}

enum BillingResolutionSourceEntityType {
  work_order
  report
  invoice
}

enum BillingResolutionMode {
  direct_customer
  contract_provider
}

enum BillingResolutionPricingSource {
  provider_contract_rate
  customer_pricing
  default_pricing
  manual_override
}

enum ComplianceReportingDivision {
  fire_extinguishers
  fire_alarm
  fire_sprinkler
  kitchen_suppression
}

enum QuoteStatus {
  draft
  ready_to_send
  sent
  viewed
  approved
  declined
  expired
  converted
  cancelled
}

enum QuoteSyncStatus {
  not_synced
  sync_pending
  synced
  sync_error
}

enum QuoteDeliveryStatus {
  not_sent
  pending
  sent
  error
}

enum QuoteReminderType {
  sent_not_viewed_first
  sent_not_viewed_second
  viewed_pending_first
  viewed_pending_second
  expiring_soon
  expired_follow_up
  manual_follow_up
}

enum QuoteReminderDispatchStatus {
  pending
  sent
  skipped
  failed
}

model SubscriptionPlan {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  monthlyPriceCents Int
  maxTenants        Int?
  maxUsers          Int?
  featureFlags      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenants           Tenant[]
}

model Tenant {
  id                        String                 @id @default(cuid())
  slug                      String                 @unique
  name                      String
  status                    TenantStatus           @default(active)
  timezone                  String                 @default("America/Chicago")
  branding                  Json?
  subscriptionPlanId        String?
  billingEmail              String?
  stripeCustomerId          String?                @unique
  stripeSubscriptionId      String?                @unique
  stripeSubscriptionStatus  String?
  stripePriceId             String?
  defaultServiceFeeCode     String?                @default("SERVICE_FEE")
  defaultServiceFeeUnitPrice Float?
  stripeCurrentPeriodEndsAt DateTime?
  stripeCancelAtPeriodEnd   Boolean                @default(false)
  stripeSubscriptionSyncedAt DateTime?
  stripeSubscriptionEventCreatedAt DateTime?
  stripeSubscriptionEventId String?
  quickbooksRealmId          String?                @unique
  quickbooksCompanyName      String?
  quickbooksConnectionMode   QuickBooksConnectionMode?
  quickbooksAccessToken      String?
  quickbooksRefreshToken     String?
  quickbooksTokenExpiresAt   DateTime?
  quickbooksConnectedAt      DateTime?
  quoteReminderSettings      Json?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  subscriptionPlan          SubscriptionPlan?      @relation(fields: [subscriptionPlanId], references: [id])
  users                     User[]
  customerCompanies         CustomerCompany[]
  sites                     Site[]
  assets                    Asset[]
  inspections               Inspection[]
  inspectionTasks           InspectionTask[]
  inspectionReports         InspectionReport[]
  recurrences               InspectionRecurrence[]
  attachments               Attachment[]
  manuals                   Manual[]
  signatures                Signature[]
  deficiencies              Deficiency[]
  billingSummaries          InspectionBillingSummary[]
  inspectionDocuments       InspectionDocument[]
  auditLogs                 AuditLog[]
  reportCorrectionEvents    ReportCorrectionEvent[]
  inspectionAmendments      InspectionAmendment[]
  inspectionCloseoutRequests InspectionCloseoutRequest[]
  inspectionTechnicianAssignments InspectionTechnicianAssignment[]
  stripeWebhookEvents       StripeWebhookEvent[]
  serviceFeeRules           ServiceFeeRule[]
  billingPayerAccounts      BillingPayerAccount[]
  billingContractProfiles   BillingContractProfile[]
  contractProviderAccounts  ContractProviderAccount[]
  providerContractProfiles  ProviderContractProfile[]
  serviceSiteProviderAssignments ServiceSiteProviderAssignment[]
  complianceReportingFeeRules ComplianceReportingFeeRule[]
  billingResolutionSnapshots BillingResolutionSnapshot[]
  quickbooksCatalogItems    QuickBooksCatalogItem[]
  quickBooksItemMaps        QuickBooksItemMap[]
  quickBooksItemCache       QuickBooksItemCache[]
  quickbooksCatalogItemAliases QuickBooksCatalogItemAlias[]
  billingItemCatalogMatches BillingItemCatalogMatch[]
  accountInvitations        AccountInvitation[]
  passwordResetTokens       PasswordResetToken[]
  quotes                    Quote[]
  quoteLineItems            QuoteLineItem[]
  quoteReminderDispatches   QuoteReminderDispatch[]
  emailReminderSendLogs     EmailReminderSendLog[]
}

model User {
  id                  String                  @id @default(cuid())
  tenantId            String?
  customerCompanyId   String?
  email               String                  @unique
  name                String
  passwordHash        String
  role                UserRole
  isActive            Boolean                 @default(true)
  allowances          Json?
  lastLoginAt         DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  tenant              Tenant?                 @relation(fields: [tenantId], references: [id])
  customerCompany     CustomerCompany?        @relation(fields: [customerCompanyId], references: [id])
  assignedInspections Inspection[]            @relation("InspectionAssignedTechnician")
  assignedInspectionTasks InspectionTask[]    @relation("InspectionTaskAssignedTechnician")
  createdInspections  Inspection[]            @relation("InspectionCreatedBy")
  inspectionReports   InspectionReport[]      @relation("InspectionReportTechnician")
  requestedReportCorrections InspectionReport[] @relation("ReportCorrectionRequestedBy")
  resolvedReportCorrections InspectionReport[] @relation("ReportCorrectionResolvedBy")
  auditLogs           AuditLog[]
  reportCorrectionEvents ReportCorrectionEvent[] @relation("ReportCorrectionEventActor")
  createdAmendments   InspectionAmendment[]   @relation("InspectionAmendmentCreatedBy")
  requestedInspectionCloseoutRequests InspectionCloseoutRequest[] @relation("InspectionCloseoutRequestRequestedBy")
  approvedInspectionCloseoutRequests InspectionCloseoutRequest[] @relation("InspectionCloseoutRequestApprovedBy")
  dismissedInspectionCloseoutRequests InspectionCloseoutRequest[] @relation("InspectionCloseoutRequestDismissedBy")
  inspectionAssignments InspectionTechnicianAssignment[]
  sentAccountInvitations AccountInvitation[]  @relation("AccountInvitationInvitedBy")
  acceptedAccountInvitations AccountInvitation[] @relation("AccountInvitationAcceptedBy")
  requestedPasswordResets PasswordResetToken[] @relation("PasswordResetRequestedBy")
  passwordResetTokens PasswordResetToken[]     @relation("PasswordResetUser")
  addedInspectionTasks InspectionTask[]        @relation("InspectionTaskAddedBy")
  createdQuotes       Quote[]                  @relation("QuoteCreatedBy")
  updatedQuotes       Quote[]                  @relation("QuoteUpdatedBy")
  pausedQuoteReminders Quote[]                @relation("QuoteRemindersPausedBy")
  sentEmailReminderLogs EmailReminderSendLog[] @relation("EmailReminderSentBy")
  createdManuals       Manual[]                @relation("ManualCreatedBy")
  updatedManuals       Manual[]                @relation("ManualUpdatedBy")
  manualStates         UserManualState[]
}

model CustomerCompany {
  id                        String   @id @default(cuid())
  tenantId                  String
  name                      String
  contactName               String?
  billingEmail              String?
  phone                     String?
  isTaxExempt               Boolean  @default(false)
  serviceAddressLine1       String?
  serviceAddressLine2       String?
  serviceCity               String?
  serviceState              String?
  servicePostalCode         String?
  serviceCountry            String?
  billingAddressSameAsService Boolean @default(true)
  billingAddressLine1       String?
  billingAddressLine2       String?
  billingCity               String?
  billingState              String?
  billingPostalCode         String?
  billingCountry            String?
  notes                     String?
  isActive                  Boolean  @default(true)
  paymentTermsCode          String   @default("due_on_receipt")
  customPaymentTermsLabel   String?
  customPaymentTermsDays    Int?
  billingType               BillingType @default(standard)
  billToAccountId           String?
  contractProfileId         String?
  invoiceDeliverySettings   Json?
  autoBillingEnabled        Boolean  @default(false)
  requiredBillingReferences Json?
  quickbooksCustomerId      String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  tenant                    Tenant   @relation(fields: [tenantId], references: [id])
  billToAccount             BillingPayerAccount? @relation("CustomerCompanyBillToAccount", fields: [billToAccountId], references: [id])
  contractProfile           BillingContractProfile? @relation(fields: [contractProfileId], references: [id])
  users                     User[]
  sites                     Site[]
  inspections               Inspection[]
  billingSummaries          InspectionBillingSummary[]
  billingResolutionSnapshots BillingResolutionSnapshot[]
  serviceFeeRules           ServiceFeeRule[]
  accountInvitations        AccountInvitation[]
  quotes                    Quote[]
  emailReminderSendLogs     EmailReminderSendLog[]

  @@index([tenantId, billingType])
  @@index([tenantId, billToAccountId])
  @@index([tenantId, contractProfileId])
}

model BillingPayerAccount {
  id                      String   @id @default(cuid())
  tenantId                String
  name                    String
  contactName             String?
  billingEmail            String?
  phone                   String?
  billingAddressLine1     String?
  billingAddressLine2     String?
  billingCity             String?
  billingState            String?
  billingPostalCode       String?
  billingCountry          String?
  invoiceDeliverySettings Json?
  quickbooksCustomerId    String?
  externalAccountCode     String?
  externalReference       String?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  tenant                  Tenant   @relation(fields: [tenantId], references: [id])
  customerCompanies       CustomerCompany[] @relation("CustomerCompanyBillToAccount")
  contractProfiles        BillingContractProfile[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model BillingContractProfile {
  id                String   @id @default(cuid())
  tenantId          String
  payerAccountId    String?
  name              String
  isActive          Boolean  @default(true)
  effectiveStartDate DateTime
  effectiveEndDate  DateTime?
  inspectionRules   Json?
  serviceRules      Json?
  emergencyRules    Json?
  deficiencyRules   Json?
  groupingRules     Json?
  attachmentRules   Json?
  deliveryRules     Json?
  referenceRules    Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  payerAccount      BillingPayerAccount? @relation(fields: [payerAccountId], references: [id])
  customerCompanies CustomerCompany[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive, effectiveStartDate])
  @@index([tenantId, payerAccountId])
}

model ContractProviderAccount {
  id                     String                        @id @default(cuid())
  organizationId         String
  name                   String
  legalName              String?
  status                 ContractProviderAccountStatus @default(active)
  billingContactName     String
  billingEmail           String
  billingPhone           String
  remittanceAddressLine1 String
  remittanceAddressLine2 String?
  remittanceCity         String
  remittanceState        String
  remittancePostalCode   String
  paymentTerms           String
  notes                  String?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  organization           Tenant                        @relation(fields: [organizationId], references: [id])
  contractProfiles       ProviderContractProfile[]
  siteAssignments        ServiceSiteProviderAssignment[]
  workOrderContexts      WorkOrderProviderContext[]
  billingResolutionSnapshots BillingResolutionSnapshot[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@unique([organizationId, name])
}

model ProviderContractProfile {
  id                             String                        @id @default(cuid())
  organizationId                 String
  providerAccountId              String
  name                           String
  status                         ProviderContractProfileStatus @default(draft)
  effectiveStartDate             DateTime
  effectiveEndDate               DateTime?
  pricingStrategy                ProviderContractPricingStrategy
  invoiceGroupingMode            ProviderInvoiceGroupingMode
  requireProviderWorkOrderNumber Boolean                       @default(false)
  requireSiteReferenceNumber     Boolean                       @default(false)
  notes                          String?
  createdAt                      DateTime                      @default(now())
  updatedAt                      DateTime                      @updatedAt
  organization                   Tenant                        @relation(fields: [organizationId], references: [id])
  providerAccount                ContractProviderAccount       @relation(fields: [providerAccountId], references: [id])
  rates                          ProviderContractRate[]
  siteAssignments                ServiceSiteProviderAssignment[]
  workOrderContexts              WorkOrderProviderContext[]
  billingResolutionSnapshots     BillingResolutionSnapshot[]

  @@index([organizationId])
  @@index([providerAccountId])
  @@index([organizationId, status])
  @@index([organizationId, providerAccountId])
  @@unique([organizationId, name])
}

model ProviderContractRate {
  id                        String                            @id @default(cuid())
  providerContractProfileId String
  serviceType               String
  inspectionType            InspectionType?
  assetCategory             String?
  reportType                String?
  pricingMethod             ProviderContractRatePricingMethod
  unitRate                  Float?
  flatRate                  Float?
  minimumCharge             Float?
  effectiveStartDate        DateTime?
  effectiveEndDate          DateTime?
  priority                  Int                               @default(0)
  createdAt                 DateTime                          @default(now())
  updatedAt                 DateTime                          @updatedAt
  providerContractProfile   ProviderContractProfile           @relation(fields: [providerContractProfileId], references: [id], onDelete: Cascade)

  @@index([providerContractProfileId])
  @@index([providerContractProfileId, priority])
  @@index([providerContractProfileId, serviceType])
}

model Site {
  id                String          @id @default(cuid())
  tenantId          String
  customerCompanyId String
  name              String
  addressLine1      String
  addressLine2      String?
  city              String
  state             String
  postalCode        String
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  customerCompany   CustomerCompany @relation(fields: [customerCompanyId], references: [id])
  assets            Asset[]
  inspections       Inspection[]
  deficiencies      Deficiency[]
  billingSummaries  InspectionBillingSummary[]
  serviceFeeRules   ServiceFeeRule[]
  quotes            Quote[]
  providerAssignments ServiceSiteProviderAssignment[]
}

model ServiceSiteProviderAssignment {
  id                        String                              @id @default(cuid())
  organizationId            String
  serviceSiteId             String
  providerAccountId         String
  providerContractProfileId String?
  status                    ServiceSiteProviderAssignmentStatus @default(active)
  externalAccountName       String?
  externalAccountNumber     String?
  externalLocationCode      String?
  effectiveStartDate        DateTime?
  effectiveEndDate          DateTime?
  billingNotes              String?
  createdAt                 DateTime                            @default(now())
  updatedAt                 DateTime                            @updatedAt
  organization              Tenant                              @relation(fields: [organizationId], references: [id])
  serviceSite               Site                                @relation(fields: [serviceSiteId], references: [id], onDelete: Cascade)
  providerAccount           ContractProviderAccount             @relation(fields: [providerAccountId], references: [id])
  providerContractProfile   ProviderContractProfile?            @relation(fields: [providerContractProfileId], references: [id])
  workOrderProviderContexts WorkOrderProviderContext[]
  billingResolutionSnapshots BillingResolutionSnapshot[]

  @@index([organizationId])
  @@index([serviceSiteId])
  @@index([providerAccountId])
  @@index([providerContractProfileId])
  @@index([organizationId, serviceSiteId])
  @@index([organizationId, status])
}

model WorkOrderProviderContext {
  id                        String                           @id @default(cuid())
  workOrderId               String                           @unique
  providerAccountId         String?
  providerContractProfileId String?
  siteProviderAssignmentId  String?
  providerWorkOrderNumber   String?
  providerReferenceNumber   String?
  sourceType                WorkOrderProviderSourceType
  createdAt                 DateTime                         @default(now())
  updatedAt                 DateTime                         @updatedAt
  workOrder                 Inspection                       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  providerAccount           ContractProviderAccount?         @relation(fields: [providerAccountId], references: [id])
  providerContractProfile   ProviderContractProfile?         @relation(fields: [providerContractProfileId], references: [id])
  siteProviderAssignment    ServiceSiteProviderAssignment?   @relation(fields: [siteProviderAssignmentId], references: [id])

  @@index([providerAccountId])
  @@index([providerContractProfileId])
  @@index([siteProviderAssignmentId])
}

model BillingResolutionSnapshot {
  id                        String                            @id @default(cuid())
  organizationId            String
  sourceEntityType          BillingResolutionSourceEntityType
  sourceEntityId            String
  resolvedMode              BillingResolutionMode
  payerCustomerId           String?
  payerProviderAccountId    String?
  providerContractProfileId String?
  siteProviderAssignmentId  String?
  pricingSource             BillingResolutionPricingSource
  pricingSourceReferenceId  String?
  resolutionReason          String?
  snapshotData              String
  createdAt                 DateTime                          @default(now())
  organization              Tenant                            @relation(fields: [organizationId], references: [id])
  payerCustomer             CustomerCompany?                  @relation(fields: [payerCustomerId], references: [id])
  payerProviderAccount      ContractProviderAccount?          @relation(fields: [payerProviderAccountId], references: [id])
  providerContractProfile   ProviderContractProfile?          @relation(fields: [providerContractProfileId], references: [id])
  siteProviderAssignment    ServiceSiteProviderAssignment?    @relation(fields: [siteProviderAssignmentId], references: [id])

  @@index([organizationId])
  @@index([organizationId, sourceEntityType, sourceEntityId])
  @@index([payerCustomerId])
  @@index([payerProviderAccountId])
  @@index([providerContractProfileId])
  @@index([siteProviderAssignmentId])
}

model Asset {
  id              String           @id @default(cuid())
  tenantId        String
  siteId          String
  name            String
  assetTag        String?
  inspectionTypes InspectionType[]
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  site            Site             @relation(fields: [siteId], references: [id])
  deficiencies    Deficiency[]
}

model Inspection {
    id                    String                  @id @default(cuid())
    tenantId              String
    customerCompanyId     String
    siteId                String
    assignedTechnicianId  String?
    createdByUserId       String
    inspectionClassification InspectionClassification @default(standard)
    isPriority            Boolean                 @default(false)
    priorityAssignedAt    DateTime?
    priorityClearedAt     DateTime?
    classificationUpdatedAt DateTime?
    status                InspectionStatus        @default(to_be_completed)
    completedAt           DateTime?
    archivedAt            DateTime?
    archiveCustomerName   String?
    archiveSiteName       String?
    archiveSiteAddress    String?
    archiveSiteCity       String?
    archiveTechnicianName String?
    archiveResultStatus   String?
    archiveInspectionTypes String[]              @default([])
    archiveDivisions      String[]               @default([])
    archiveHasDeficiencies Boolean               @default(false)
    archiveDeficiencyCount Int                   @default(0)
    archiveHasReport      Boolean                @default(false)
    scheduledStart        DateTime
    scheduledEnd          DateTime?
    notes                 String?
    claimable             Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  tenant                Tenant                  @relation(fields: [tenantId], references: [id])
  customerCompany       CustomerCompany         @relation(fields: [customerCompanyId], references: [id])
  site                  Site                    @relation(fields: [siteId], references: [id])
  assignedTechnician    User?                   @relation("InspectionAssignedTechnician", fields: [assignedTechnicianId], references: [id])
  attachments           Attachment[]
  createdBy             User                    @relation("InspectionCreatedBy", fields: [createdByUserId], references: [id])
  tasks                 InspectionTask[]
  reports               InspectionReport[]
  deficiencies          Deficiency[]
  billingSummary        InspectionBillingSummary?
    documents             InspectionDocument[]
      amendments            InspectionAmendment[]   @relation("OriginalInspectionAmendments")
      replacementAmendments InspectionAmendment[]   @relation("ReplacementInspectionAmendments")
      closeoutRequest       InspectionCloseoutRequest?
      createdFromCloseoutRequests InspectionCloseoutRequest[] @relation("InspectionCloseoutRequestCreatedInspection")
      technicianAssignments InspectionTechnicianAssignment[]
      providerContext       WorkOrderProviderContext?
      convertedFromQuotes   Quote[]                 @relation("QuoteConvertedInspection")

    @@index([tenantId, inspectionClassification])
    @@index([tenantId, isPriority])
    @@index([tenantId, archivedAt])
    @@index([tenantId, completedAt])
    @@index([tenantId, archiveCustomerName])
    @@index([tenantId, archiveSiteName])
    @@index([tenantId, archiveSiteCity])
    @@index([tenantId, archiveTechnicianName])
  }

model Quote {
  id                      String              @id @default(cuid())
  tenantId                String
  quoteNumber             String
  customerCompanyId       String
  siteId                  String?
  contactName             String?
  recipientEmail          String?
  proposalType            String?
  status                  QuoteStatus         @default(draft)
  syncStatus              QuoteSyncStatus     @default(not_synced)
  deliveryStatus          QuoteDeliveryStatus @default(not_sent)
  quickbooksEstimateId    String?
  quickbooksEstimateNumber String?
  quickbooksConnectionMode QuickBooksConnectionMode?
  quickbooksCustomerId    String?
  quickbooksSyncedAt      DateTime?
  quickbooksSyncError     String?
  issuedAt                DateTime            @default(now())
  expiresAt               DateTime?
  sentAt                  DateTime?
  lastSentAt              DateTime?
  resendCount             Int                 @default(0)
  viewedAt                DateTime?
  firstViewedAt           DateTime?
  lastViewedAt            DateTime?
  viewCount               Int                 @default(0)
  customerResponseNote    String?
  lastAccessedByEmail     String?
  quoteAccessToken        String?             @unique
  quoteAccessTokenExpiresAt DateTime?
  quoteAccessTokenRevokedAt DateTime?
  quoteAccessTokenSentToEmail String?
  remindersEnabled        Boolean             @default(true)
  remindersPausedAt       DateTime?
  remindersPausedByUserId String?
  nextReminderAt          DateTime?
  lastReminderAt          DateTime?
  reminderStage           String?
  reminderCount           Int                 @default(0)
  reminderError           String?
  approvedAt              DateTime?
  declinedAt              DateTime?
  convertedAt             DateTime?
  subtotal                Float               @default(0)
  taxAmount               Float               @default(0)
  total                   Float               @default(0)
  internalNotes           String?
  customerNotes           String?
  deliverySubject         String?
  deliveryBody            String?
  lastSentToEmail         String?
  lastDeliveryMessageId   String?
  lastDeliveryError       String?
  deliveryAttempts        Int                 @default(0)
  convertedInspectionId   String?
  createdByUserId         String
  updatedByUserId         String
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  tenant                  Tenant              @relation(fields: [tenantId], references: [id])
  customerCompany         CustomerCompany     @relation(fields: [customerCompanyId], references: [id])
  site                    Site?               @relation(fields: [siteId], references: [id])
  createdBy               User                @relation("QuoteCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy               User                @relation("QuoteUpdatedBy", fields: [updatedByUserId], references: [id])
  remindersPausedBy       User?               @relation("QuoteRemindersPausedBy", fields: [remindersPausedByUserId], references: [id])
  convertedInspection     Inspection?         @relation("QuoteConvertedInspection", fields: [convertedInspectionId], references: [id])
  lineItems               QuoteLineItem[]
  reminderDispatches      QuoteReminderDispatch[]

  @@unique([tenantId, quoteNumber])
  @@index([tenantId, status])
  @@index([tenantId, syncStatus])
  @@index([tenantId, customerCompanyId])
  @@index([tenantId, siteId])
